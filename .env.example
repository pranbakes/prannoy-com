# Copy this file to .env.local for local development, and set the same
# names in Vercel's Project Settings -> Environment Variables for deployment.

# Public site URL. Used for RSS links, sitemap URLs, and OG image resolution.
NEXT_PUBLIC_SITE_URL=https://prannoy.com

# --- Keystatic GitHub mode (production only — see README/GitHub App walkthrough) ---
# Not needed for local dev; local dev always uses local filesystem storage.

# "owner/repo", e.g. "prannoy/prannoy-com". Public because the browser-side
# Keystatic app builds its GitHub API queries from this directly.
NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO=

# From your GitHub App's settings page.
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# A random secret Keystatic uses to sign session cookies. Generate with:
#   openssl rand -hex 32
KEYSTATIC_SECRET=

# Your GitHub App's slug (the part of the URL at github.com/apps/<slug>).
# Public because the browser needs it to build the GitHub install/auth URL.
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# --- Buttondown newsletter ---
# Secret API key from https://buttondown.com/settings/api. Server-side only.
BUTTONDOWN_API_KEY=
